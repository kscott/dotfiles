---
doing_file: "~/Notes/doing.md"
current_section: Currently
editor_app: MacVim
templates:
  default:
    date_format: "%Y-%m-%d %H:%M"
    template: "%date | %title%note"
    wrap_width: 0
  today:
    date_format: "%_I:%M%P"
    template: "%date: %title%note"
    wrap_width: 0
  last:
    date_format: "%-I:%M%P on %a"
    template: "%title (at %date)%odnote"
    wrap_width: 88
  recent:
    date_format: "%_I:%M%P"
    template: "%shortdate: %title"
    wrap_width: 88
views:
  sample:
    date_format: "%_I:%M%P"
    template: "%date | %title%note"
    wrap_width: 0
    section: section_name
    count: 5
  color:
    date_format: "%F %_I:%M%P"
    section: Currently
    count: 10
    wrap_width: 0
    template: "%boldblack%date %boldgreen| %boldwhite%title%default%note"
:include_notes: true
marker_tag: flagged
marker_color: red
default_tags: []
