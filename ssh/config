Host *
  AddKeysToAgent yes
  UseKeychain yes
  IdentityFile ~/.ssh/id_ed25519

Host plex
  HostName 192.168.1.25
  User ken
  IdentityFile ~/.ssh/id_ed25519
  IdentitiesOnly yes
  KexAlgorithms -mlkem768x25519-sha256

Host secondo
  HostName secondo.home
  User ken

Host quarto
  HostName quarto.home
  User ken

Host router
  HostName 192.168.1.1
  User root
  IdentityFile ~/.ssh/id_ed25519
  IdentitiesOnly yes

Host vault
  HostName 192.168.1.2
  User root
  IdentityFile ~/.ssh/id_ed25519
  IdentitiesOnly yes

Host github.com
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519
