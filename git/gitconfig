[core]
	editor = vim -f
	excludesfile = ~/.gitignore
	pager = delta

[interactive]
	diffFilter = delta --color-only --features=interactive

[user]
	name = Ken Scott
	email = ken@optikos.net

[color]
	diff = auto
	status = auto
	branch = auto
	ui = auto

[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green

[color "diff"]
	meta = yellow bold
	frag = magenta bold
	old = red reverse
	new = cyan reverse
	whitespace = yellow reverse

[color "status"]
	added = green
	changed = red
	untracked = cyan

[alias]
	aa = add --all
	amend = commit --amend
	bb = for-each-ref --format='%(color:cyan)%(authordate:format:%m/%d/%Y %I:%M %p)    %(align:25,left)%(color:yellow)%(authorname)%(end) %(color:reset)%(refname:strip=3)' --sort=authordate refs/remotes
	br = branch
	catchup = smart-pull
	cp = cherry-pick --edit
	dc = diff --cached
	del = delete-branch
	delete = delete-branch
	info = remote show origin
	l = "!source ~/.githelpers && pretty_git_log"
	la = !git l --all
	lc = log ORIG_HEAD.. --stat --no-merges
	lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %C(bold green)(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative
	pushpr = push -u origin HEAD
	pushf = push --force-with-lease
	prune = remote prune origin
	prune-all = !git remote | xargs -n 1 git remote prune
	s = status
	slog = smart-log
	sm = smart-merge
	st = status -sb
	subdo = submodule foreach git
	sw = checkout
	u = undo --hard
	up = smart-pull

[merge]
	tool = opendiff
	log = true

[mergetool]
	keepBackup = false

[push]
	default = simple

[rerere]
	enabled = 1

[commit]
	template = ~/.gitmessage

[help]
	autocorrect = 1

[diff]
	algorithm = patience

[rebase]
	autosquash = true

[init]
	defaultBranch = main

[delta]
	features = decorations side-by-side line-numbers

[delta "interactive"]
	keep-plus-minus-markers = false

[delta "decorations"]
	commit-decoration-style = blue ol
	commit-style = raw
	file-style = omit
	hunk-header-decoration-style = blue box
	hunk-header-file-style = red
	hunk-header-line-number-style = "#067a00"
	hunk-header-style = file line-number syntax

[credential "https://github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential

[credential "https://gist.github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
