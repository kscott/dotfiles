#!/usr/bin/env bash
# Claude Code SessionStart hook. Two independent jobs, both fast-forward-only
# or info-only — never a rebase, never a merge, never touches a dirty tree:
#   1. Sync the current branch against its own remote tracking branch.
#   2. If on a non-trunk branch, flag (never act on) trunk having moved ahead.
# Always exits 0 — never blocks session startup.

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || exit 0
git remote get-url origin >/dev/null 2>&1 || exit 0
git fetch --quiet >/dev/null 2>&1 || exit 0

current=$(git symbolic-ref --short HEAD 2>/dev/null) || exit 0 # skip detached HEAD
clean=false
[ -z "$(git status --porcelain 2>/dev/null)" ] && clean=true

messages=()

# --- Job 1: current branch vs its own upstream ---
if git rev-parse --abbrev-ref --symbolic-full-name @{u} >/dev/null 2>&1; then
	if $clean; then
		git pull --ff-only >/dev/null 2>&1 || true
	else
		behind=$(git rev-list --count HEAD..@{u} 2>/dev/null || echo 0)
		if [ "${behind:-0}" -gt 0 ]; then
			messages+=("origin/${current} is ${behind} commit(s) ahead but the working tree isn't clean, so it wasn't auto-pulled.")
		fi
	fi
fi

# --- Job 2: has trunk moved ahead of this branch? (never rebased/merged automatically) ---
trunk_ref=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null)
trunk=${trunk_ref##*/}
if [ -z "$trunk" ]; then
	for candidate in main master; do
		git show-ref --verify --quiet "refs/remotes/origin/$candidate" && {
			trunk=$candidate
			break
		}
	done
fi

if [ -n "$trunk" ] && [ "$current" != "$trunk" ] && git show-ref --verify --quiet "refs/remotes/origin/$trunk"; then
	ahead=$(git rev-list --count "${current}..origin/${trunk}" 2>/dev/null || echo 0)
	if [ "${ahead:-0}" -gt 0 ]; then
		messages+=("origin/${trunk} has ${ahead} commit(s) not in this branch (${current}) — not rebased or merged automatically.")
	fi
fi

if [ "${#messages[@]}" -gt 0 ]; then
	repo=$(basename "$(git rev-parse --show-toplevel)")
	joined=$(printf '%s ' "${messages[@]}")
	joined=${joined% }
	echo "{\"systemMessage\": \"${repo}: ${joined}\"}"
fi

exit 0
