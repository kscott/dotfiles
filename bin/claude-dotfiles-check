#!/usr/bin/env bash
# Claude Code SessionStart hook, scoped to specific project repos (not global).
# Notification-only: checks whether ~/dotfiles is behind its own remote and
# says so via systemMessage. Never pulls, never touches ~/dotfiles at all.
# Always exits 0 — never blocks session startup.

DOTFILES="$HOME/dotfiles"

git -C "$DOTFILES" rev-parse --is-inside-work-tree >/dev/null 2>&1 || exit 0
git -C "$DOTFILES" remote get-url origin >/dev/null 2>&1 || exit 0
git -C "$DOTFILES" fetch --quiet >/dev/null 2>&1 || exit 0
git -C "$DOTFILES" rev-parse --abbrev-ref --symbolic-full-name @{u} >/dev/null 2>&1 || exit 0

behind=$(git -C "$DOTFILES" rev-list --count HEAD..@{u} 2>/dev/null || echo 0)
if [ "${behind:-0}" -gt 0 ]; then
	branch=$(git -C "$DOTFILES" symbolic-ref --short HEAD 2>/dev/null)
	note=""
	[ -n "$(git -C "$DOTFILES" status --porcelain 2>/dev/null)" ] && note=" (dotfiles working tree isn't clean — resolve that before pulling)"
	echo "{\"systemMessage\": \"dotfiles is ${behind} commit(s) behind origin/${branch}${note}. Pull to pick up global settings changes.\"}"
fi

exit 0
